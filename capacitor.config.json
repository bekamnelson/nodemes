{
  "appId": "com.pixichat.app",
  "appName": "PixiChat",
  "webDir": "public",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "nodemes-3.onrender.com",
      "res.cloudinary.com",
      "*.cloudinary.com"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0e0e18",
      "showSpinner": false
    }
  }
}
